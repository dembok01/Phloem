{
  "key": "feedback_nutrition",
  "version": 1,
  "title": "Monthly Nutrition Feedback",
  "sections": [
    { "id": "s1", "title": "This Month", "fields": [
      { "id": "adherence",        "type": "scale_1_5", "label": "Adherence to the plan", "required": true },
      { "id": "adherence_basis",  "type": "text",      "label": "What is this adherence rating based on?", "required": true },
      { "id": "weight_change",    "type": "text",      "label": "Weight change" },
      { "id": "worked_well",      "type": "textarea",  "label": "What worked well", "required": true },
      { "id": "challenges",       "type": "textarea",  "label": "Challenges", "required": true },
      { "id": "reported_changes", "type": "textarea",  "label": "Reported changes", "hint": "energy, digestion, appetite" },
      { "id": "modifications",    "type": "textarea",  "label": "Plan modifications made / proposed" },
      { "id": "doctor_flags",     "type": "textarea",  "label": "Anything the doctor should know before the review call" },
      { "id": "next_focus",       "type": "textarea",  "label": "Next month's focus", "required": true }
    ]}
  ]
}
